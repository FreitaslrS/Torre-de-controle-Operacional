# Torre de Controle — variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA versione o .env com credenciais reais.

# ── Bancos de dados (Neon.tech) ───────────────────────────────────────
DATABASE_URL_BACKLOG=postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL_OPERACIONAL=postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL_HISTORICO=postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL_DEVOLUCOES=postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL_PROCESSAMENTO=postgresql://usuario:senha@host/banco?sslmode=require
DATABASE_URL_COLETAS=postgresql://usuario:senha@host/banco?sslmode=require

# ── Autenticação da página de Importação ─────────────────────────────
# Mínimo 12 caracteres, com maiúsculas, minúsculas, números e símbolos.
SENHA_IMPORTACAO=coloque_uma_senha_forte_aqui
